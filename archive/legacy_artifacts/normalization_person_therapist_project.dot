// Normalization Diagram
digraph {
	graph [fontname="Times New Roman" rankdir=TB]
	node [fontname="Times New Roman" shape=record]
	PERSON [label="{PERSON | Person_ID (PK) | Name | Rank | Age | Gender | Service_Years}"]
	THERAPIST [label="{THERAPIST | Therapist_ID (PK) | Name | Qualification | Specialization | Experience}"]
	SCENARIO [label="{SCENARIO | Scenario_ID (PK) | Scenario_Type | Environment | Assigned_Date}"]
	REACTION [label="{REACTION | Reaction_ID (PK) | Reaction_Type | Physical_Response}"]
	REPORT [label="{REPORT | Report_ID (PK) | Reaction_ID (FK) | Person_ID (FK) | Therapist_ID (FK) | Avoidance | Re_Experiencing | Negative_Alterations | Hyperarousal}"]
	PERSON -> PERSON [label="Person_ID → All Attributes"]
	THERAPIST -> THERAPIST [label="Therapist_ID → All Attributes"]
	SCENARIO -> SCENARIO [label="Scenario_ID → All Attributes"]
	REACTION -> REACTION [label="Reaction_ID → All Attributes"]
	REPORT -> REPORT [label="Report_ID → All Attributes"]
	NF [label="{NORMAL FORMS | 1NF : ✔ | 2NF : ✔ | 3NF : ✔ | BCNF : ✔}"]
	REPORT -> NF
}
